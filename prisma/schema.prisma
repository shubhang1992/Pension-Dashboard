generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PensionFundManager {
  id        Int              @id @default(autoincrement())
  name      String
  aum       Float
  city      String?
  state     String?
  schemes   PensionScheme[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model PensionScheme {
  id          Int                @id @default(autoincrement())
  name        String
  category    String?
  riskLevel   String?
  aum         Float?
  manager     PensionFundManager @relation(fields: [managerId], references: [id])
  managerId   Int
  launchedAt  DateTime?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model SchemeAumHistory {
  id              Int      @id @default(autoincrement())
  asOfDate        DateTime
  fundManagerName String
  schemeName      String
  aumCrore        Float?
  subscribers     Int?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([asOfDate, fundManagerName, schemeName])
}

/// State/UT-wise snapshot (e.g. from PFRDA state-wise reports or OGD).
/// When present, state panel shows this; otherwise falls back to All-India totals.
model StateWiseSnapshot {
  id                 Int      @id @default(autoincrement())
  stateName          String
  asOfDate           DateTime
  subscribers        Int?
  aumCrore           Float?
  /// From M7: cumulative SG-sector contribution (sum of all months, ₹ Cr)
  contributionCrore  Float?
  /// From A6: Female / Male / Transgender (APY state-wise)
  genderFemale       Int?
  genderMale         Int?
  genderTransgender  Int?
  /// From A22: age-band wise (NPS All Citizen). JSON e.g. {"18-20": 100, "21-25": 200, ...}
  ageBreakdown       Json?
  /// Optional monthly SG contribution history from M7, e.g. {"Dec-2014": 10.5, ...}
  contributionHistory Json?

  createdAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([stateName, asOfDate])
}